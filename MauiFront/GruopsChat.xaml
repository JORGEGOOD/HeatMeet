<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiFront.GroupsChat"
             BackgroundColor="#F5F0E8">

    <Grid RowDefinitions="70,*,70">

        <!-- HEADER -->
        <Grid Grid.Row="0"
              BackgroundColor="White"
              Padding="10,0"
              ColumnDefinitions="40,50,*,40">

            <Label Grid.Column="0"
                   Text="←"
                   FontSize="22"
                   VerticalOptions="Center"
                   HorizontalOptions="Center">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBackTapped"/>
                </Label.GestureRecognizers>
            </Label>

            <!-- Avatar circular -->
            <Frame Grid.Column="1"
                   WidthRequest="40"
                   HeightRequest="40"
                   CornerRadius="20"
                   BackgroundColor="#E03030"
                   BorderColor="Transparent"
                   Padding="0"
                   IsClippedToBounds="True"
                   VerticalOptions="Center"
                   HorizontalOptions="Center">
                <Label Text=" "
                       TextColor="White"
                       FontSize="17"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"/>
            </Frame>

            <!-- Nombre del grupo -->
            <Label Grid.Column="2"
                   Text="(NameGroup)"
                   FontSize="16"
                   FontAttributes="Bold"
                   VerticalOptions="Center"
                   Margin="8,0,0,0"/>

            <!-- Tres puntos -->
            <Label Grid.Column="3"
                   Text="⋮"
                   FontSize="22"
                   VerticalOptions="Center"
                   HorizontalOptions="Center"/>
        </Grid>

        <!-- Messages -->
        <ScrollView Grid.Row="1" Padding="15,10">
            <VerticalStackLayout x:Name="MessagesContainer" Spacing="10">
                
                
                <!--Its null on the start-->
                
                
            </VerticalStackLayout>
        </ScrollView>

        <!-- BARRA INFERIOR -->
        <Grid Grid.Row="2"
              BackgroundColor="White"
              Padding="10,0"
              ColumnDefinitions="*,45">

            <Frame Grid.Column="0"
                   BorderColor="#DDDDDD"
                   CornerRadius="20"
                   Padding="15,0"
                   HeightRequest="42"
                   VerticalOptions="Center">
                <Entry x:Name="MessageEntry"
                       Placeholder="Escribe un mensaje..."
                       PlaceholderColor="#AAAAAA"
                       FontSize="14"
                       VerticalOptions="Center"/>
            </Frame>

            <Frame Grid.Column="1"
                   WidthRequest="40"
                   HeightRequest="40"
                   CornerRadius="20"
                   BackgroundColor="#F07030"
                   BorderColor="Transparent"
                   Padding="0"
                   IsClippedToBounds="True"
                   VerticalOptions="Center"
                   HorizontalOptions="Center">
                <Label Text="➤"
                       TextColor="White"
                       FontSize="16"
                       HorizontalOptions="Center"
                       VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnSendTapped"/>
                    </Label.GestureRecognizers>
                </Label>
            </Frame>

        </Grid>
    </Grid>
</ContentPage>