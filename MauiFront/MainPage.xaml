<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiFront.MainPage">

    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="30">
            <Label Text="LOGIN" 
               FontSize="40" 
               HorizontalOptions="Center" 
               TextColor="Purple" />

            <Entry x:Name="userEntry"  Placeholder="Usuario" />
            <Entry x:Name="passwordEntry" Placeholder="Contraseña" IsPassword="True" />
            <Button Text="Entrar" BackgroundColor="Blue" Clicked="BotonEntrar" />
            
            
            <Button Text="Crear Nuevo grupo" BackgroundColor="Blue" Clicked="CrearNuevoGrupo" />
            
            
            
            
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
