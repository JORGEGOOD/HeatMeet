<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiFront.MainPage"
             BackgroundColor="#F5EDE3">

    <ScrollView>
        <VerticalStackLayout 
            VerticalOptions="Center" 
            HorizontalOptions="Center"
            Padding="30">

            <!-- Card principal con borde azul -->
            <Frame
                CornerRadius="28"
                BackgroundColor="White"
                Padding="30"
                WidthRequest="330"
                BorderColor="#0A2A43"
                HasShadow="True"
                Shadow="{Shadow Brush='#20000000', Offset='0,6', Radius='18'}"
                >

                <VerticalStackLayout Spacing="22">

                    <!-- Título -->
                    <Label Text="Bienvenido"
                           FontSize="28"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"
                           TextColor="#072033"/>

                    <Label Text="Inicia sesión"
                           FontSize="14"
                           HorizontalOptions="Center"
                           TextColor="#0A2A43"
                           Opacity="0.7"/>

                    <!-- Usuario -->
                    <Entry x:Name="userEntry"
                           Placeholder="Usuario"
                           TextColor="#072033"
                           PlaceholderColor="#8A8A8A"
                           HeightRequest="48"
                           FontSize="14"/>

                    <!-- Contraseña -->
                    <Entry x:Name="passwordEntry"
                           Placeholder="Contraseña"
                           IsPassword="True"
                           TextColor="#072033"
                           PlaceholderColor="#8A8A8A"
                           HeightRequest="48"
                           FontSize="14"/>

                    <!-- Botón principal -->
                    <Grid>
                        <Button x:Name="loginButton"
                                Text="Entrar"
                                Clicked="BotonEntrar"
                                HeightRequest="52"
                                CornerRadius="14"
                                TextColor="White"
                                FontAttributes="Bold"
                                FontSize="16">
                            <Button.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#FF6A00" Offset="0.0"/>
                                    <GradientStop Color="#E63900" Offset="1.0"/>
                                </LinearGradientBrush>
                            </Button.Background>
                            <Button.Shadow>
                                <Shadow Brush="#30000000" Offset="0,4" Radius="12"/>
                            </Button.Shadow>
                        </Button>

                        <ActivityIndicator x:Name="loader"
                                           IsVisible="False"
                                           IsRunning="False"
                                           Color="White"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"/>
                    </Grid>

                    <!-- Enlaces -->
                    <Button Text="¿No tienes cuenta? Regístrate"
                            Clicked="BotonRegistrar"
                            BackgroundColor="Transparent"
                            TextColor="#072033"
                            FontSize="12"
                            BorderWidth="0"
                            Opacity="0.7"/>

                </VerticalStackLayout>
            </Frame>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
