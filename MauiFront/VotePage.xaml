<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:scheduler="clr-namespace:Syncfusion.Maui.Scheduler;assembly=Syncfusion.Maui.Scheduler"
             x:Class="MauiFront.VotePage"
             BackgroundColor="#F1EEE8">
    <ScrollView>
        <VerticalStackLayout Padding="2,20" Spacing="20">

            <VerticalStackLayout Spacing="4">
                <Label Text="HeatMeet"
                       FontSize="32"
                       FontAttributes="Bold"
                       TextColor="#1E2A4A"
                       HorizontalOptions="Center"/>
                <Label Text="Es hora de tomar una desición"
                       FontSize="15"
                       TextColor="#707070"
                       HorizontalOptions="Center"
                       Margin="0,0,0,10"/>
            </VerticalStackLayout>

            <Frame HeightRequest="500" 
               Margin="15,15,15,5"
               BackgroundColor="White"
               CornerRadius="20"
               BorderColor="Transparent"
               HasShadow="True"
               Padding="0">

                <scheduler:SfScheduler x:Name="SchedulerControl"
                   View="Month"
                   Tapped="OnSchedulerTapped"
                   AppointmentsSource="{Binding EventosAgendados}">
                </scheduler:SfScheduler>

            </Frame>

            <Frame BackgroundColor="White" BorderColor="Transparent" CornerRadius="14" Padding="20" HasShadow="True">
                <VerticalStackLayout Spacing="18">

                    

                    <Label Text="Detalles de la Propuesta" FontSize="18" FontAttributes="Bold" TextColor="#1E2A4A"/>


                    <VerticalStackLayout Spacing="5">
                        <Label Text="Nombre del plan"
                           FontSize="13"
                           TextColor="#1E2A4A"
                           FontAttributes="Bold"/>
                        <Frame BorderColor="#DDDDDD"
                           Padding="15,0"
                           CornerRadius="8"
                           HeightRequest="48"
                           BackgroundColor="#F8F8F8">
                            <Label x:Name="TituloLabel"
                           TextColor="#072033"
                           FontSize="14"
                           VerticalOptions="Center"/>
                        </Frame>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="5">
                        <Label Text="Lugar"
           FontSize="13"
           TextColor="#1E2A4A"
           FontAttributes="Bold"/>
                        <Frame BorderColor="#DDDDDD"
           Padding="15,0"
           CornerRadius="8"
           HeightRequest="48"
           BackgroundColor="#F8F8F8">
                            <Label x:Name="UbicacionLabel"
               TextColor="#072033"
               FontSize="14"
               VerticalOptions="Center"/>
                        </Frame>
                    </VerticalStackLayout>



                    <<VerticalStackLayout Grid.Column="0" Spacing="5">
                        <Label Text="Dia"
                           FontSize="13"
                           TextColor="#1E2A4A"
                           FontAttributes="Bold"/>
                        <Frame BorderColor="#DDDDDD"
                       Padding="15,0"
                       CornerRadius="8"
                       HeightRequest="48"
                       BackgroundColor="#F8F8F8">
                            <Label x:Name="FechaLabel"
               TextColor="#072033"
               FontSize="14"
               VerticalOptions="Center"/>
                        </Frame>
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="1" Spacing="5">
                    <Label Text="Hora"
               FontSize="13"
               TextColor="#1E2A4A"
               FontAttributes="Bold"/>
                    <Frame BorderColor="#DDDDDD"
               Padding="15,0"
               CornerRadius="8"
               HeightRequest="48"
               BackgroundColor="#F8F8F8">
                        <Label x:Name="HoraLabel"
               TextColor="#072033"
               FontSize="14"
               VerticalOptions="Center"/>
                    </Frame>
                </VerticalStackLayout>

                <Button Text="No, estoy deacuerdo"
                        Clicked="EventoNulo"
                        TextColor="White" 
                        CornerRadius="14" 
                        HeightRequest="56"
                        FontAttributes="Bold"
                        FontSize="16"
                        Margin="0,20,0,0">
                        <Button.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#FF6A00" Offset="0.0"/>
                                <GradientStop Color="#E63900" Offset="1.0"/>
                            </LinearGradientBrush>
                        </Button.Background>
                    </Button>
                    <Button Text="Si, estoy dea"
                        Clicked="EventoAceptado"
                        TextColor="White" 
                        CornerRadius="14" 
                        HeightRequest="56"
                        FontAttributes="Bold"
                        FontSize="16"
                        Margin="0,20,0,0">  
                        <Button.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#FF6A00" Offset="0.0"/>
                                <GradientStop Color="#E63900" Offset="1.0"/>
                            </LinearGradientBrush>
                        </Button.Background>
                    </Button>

                </VerticalStackLayout>
            </Frame>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>