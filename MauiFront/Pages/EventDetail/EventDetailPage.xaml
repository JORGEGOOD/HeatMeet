<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiFront.EventDetailPage"
             Title="Detalles del evento"
             BackgroundColor="#F1EEE8">

    <ScrollView>
        <VerticalStackLayout Padding="24,40" Spacing="20">

            <VerticalStackLayout Spacing="4">
                <Label Text="HeatMeet"
                       FontSize="32"
                       FontAttributes="Bold"
                       TextColor="#1E2A4A"
                       HorizontalOptions="Center"/>
                <Label Text="Detalles de la quedada"
                       FontSize="15"
                       TextColor="#707070"
                       HorizontalOptions="Center"
                       Margin="0,0,0,10"/>
            </VerticalStackLayout>

            <Frame BackgroundColor="White"
                   BorderColor="Transparent"
                   CornerRadius="14"
                   Padding="20"
                   HasShadow="True">
                <VerticalStackLayout Spacing="18">

                    <Label Text="Información del plan"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="#1E2A4A"/>

                    <VerticalStackLayout Spacing="5">
                        <Label Text="Nombre del plan"
                               FontSize="13"
                               TextColor="#1E2A4A"
                               FontAttributes="Bold"/>
                        <Frame BorderColor="#DDDDDD"
                               Padding="15,0"
                               CornerRadius="8"
                               HeightRequest="48"
                               BackgroundColor="#F8F8F8">
                            <Label x:Name="TituloLabel"
                                   TextColor="#072033"
                                   FontSize="14"
                                   VerticalOptions="Center"/>
                        </Frame>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="5">
                        <Label Text="Lugar"
                               FontSize="13"
                               TextColor="#1E2A4A"
                               FontAttributes="Bold"/>
                        <Frame BorderColor="#DDDDDD"
                               Padding="15,0"
                               CornerRadius="8"
                               HeightRequest="48"
                               BackgroundColor="#F8F8F8">
                            <Label x:Name="UbicacionLabel"
                                   TextColor="#072033"
                                   FontSize="14"
                                   VerticalOptions="Center"/>
                        </Frame>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="5">
                        <Label Text="Direccion"
                               FontSize="13"
                               TextColor="#1E2A4A"
                               FontAttributes="Bold"/>
                        <Frame BorderColor="#DDDDDD"
                               Padding="15,0"
                               CornerRadius="8"
                               HeightRequest="48"
                               BackgroundColor="#F8F8F8">
                            <Label x:Name="DireccionLabel"
                                   TextColor="#072033"
                                   FontSize="14"
                                   VerticalOptions="Center"/>
                        </Frame>
                    </VerticalStackLayout>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">

                        <VerticalStackLayout Grid.Column="0" Spacing="5">
                            <Label Text="Dia"
                                   FontSize="13"
                                   TextColor="#1E2A4A"
                                   FontAttributes="Bold"/>
                            <Frame BorderColor="#DDDDDD"
                                   Padding="15,0"
                                   CornerRadius="8"
                                   HeightRequest="48"
                                   BackgroundColor="#F8F8F8">
                                <Label x:Name="FechaLabel"
                                       TextColor="#072033"
                                       FontSize="14"
                                       VerticalOptions="Center"/>
                            </Frame>
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1" Spacing="5">
                            <Label Text="Hora"
                                   FontSize="13"
                                   TextColor="#1E2A4A"
                                   FontAttributes="Bold"/>
                            <Frame BorderColor="#DDDDDD"
                                   Padding="15,0"
                                   CornerRadius="8"
                                   HeightRequest="48"
                                   BackgroundColor="#F8F8F8">
                                <Label x:Name="HoraLabel"
                                       TextColor="#072033"
                                       FontSize="14"
                                       VerticalOptions="Center"/>
                            </Frame>
                        </VerticalStackLayout>

                    </Grid>

                </VerticalStackLayout>
            </Frame>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
