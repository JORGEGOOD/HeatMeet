<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiFront.UserGroups"
             BackgroundColor="#F5EDE3">

    <Grid RowDefinitions="Auto,*">

        <!-- Título -->
        <VerticalStackLayout Grid.Row="0" Padding="20,20,20,10" Spacing="4">
            <Label x:Name="GroupNameLabel"
                   FontSize="22"
                   FontAttributes="Bold"
                   TextColor="#0A2A43"/>
            <Label x:Name="MemberCountLabel"
                   FontSize="13"
                   TextColor="#888"/>
        </VerticalStackLayout>

        <!-- Lista miembros -->
        <CollectionView Grid.Row="1"
                        x:Name="MembersCollection"
                        Margin="16,0,16,10"
                        SelectionMode="None">
            <CollectionView.EmptyView>
                <Label Text="No hay miembros en este grupo."
                       TextColor="#4A6580"
                       FontSize="14"
                       HorizontalOptions="Center"
                       Margin="0,40,0,0"/>
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="0,6"
                           Padding="16,12"
                           CornerRadius="16"
                           BackgroundColor="White"
                           BorderColor="Transparent"
                           HasShadow="True">
                        <Grid ColumnDefinitions="50,*">

                            <!-- Avatar con inicial -->
                            <Frame Grid.Column="0"
                                   WidthRequest="44"
                                   HeightRequest="44"
                                   CornerRadius="22"
                                   BackgroundColor="#0A2A43"
                                   BorderColor="Transparent"
                                   HasShadow="False"
                                   Padding="0"
                                   VerticalOptions="Center">
                                <Label Text="{Binding Inicial}"
                                       FontSize="18"
                                       FontAttributes="Bold"
                                       TextColor="White"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"/>
                            </Frame>

                            <!-- Nombre y email -->
                            <VerticalStackLayout Grid.Column="1"
                                                 VerticalOptions="Center"
                                                 Spacing="2">
                                <Label Text="{Binding Name}"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       TextColor="#072033"/>
                                <Label Text="{Binding Email}"
                                       FontSize="12"
                                       TextColor="#888"/>
                            </VerticalStackLayout>

                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>
</ContentPage>