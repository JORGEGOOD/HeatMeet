<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiFront.EventPage"
             BackgroundColor="#F5EDE3">

    <Grid RowDefinitions="Auto,*">

        <Label Grid.Row="0"
               Text="Mis Eventos"
               FontSize="22"
               FontAttributes="Bold"
               TextColor="#1E2A4A"
               Margin="20,20,20,8"/>

        <CollectionView Grid.Row="1"
                        x:Name="EventsCollection"
                        Margin="16,0,16,10"
                        SelectionMode="None">
            <CollectionView.EmptyView>
                <Label Text="No hay eventos en este grupo todavía."
                       TextColor="#4A6580"
                       FontSize="14"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"
                       Margin="0,40,0,0"/>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="0,6"
                           Padding="14,12"
                           CornerRadius="18"
                           BackgroundColor="White"
                           BorderColor="Transparent"
                           HasShadow="True">

                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnEventCardTapped" />
                        </Frame.GestureRecognizers>

                        <HorizontalStackLayout Spacing="14">

                            <Frame CornerRadius="15"
                                   Padding="0"
                                   HeightRequest="48"
                                   WidthRequest="48"
                                   BackgroundColor="Transparent"
                                   BorderColor="Transparent"
                                   IsClippedToBounds="True"
                                   HasShadow="False"
                                   VerticalOptions="Center">
                                <Image Source="logo.png" Aspect="AspectFill"/>
                            </Frame>

                            <VerticalStackLayout VerticalOptions="Center" Spacing="3" HorizontalOptions="FillAndExpand">
                                <Label Text="{Binding Title}"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       TextColor="#072033"/>
                                <Label Text="{Binding FechaHoraFormatted}"
                                       FontSize="12"
                                       TextColor="#4A6580"/>
                            </VerticalStackLayout>

                            <Label Text="›"
                                   FontSize="28"
                                   TextColor="#C0CEDB"
                                   VerticalOptions="Center"
                                   Margin="0,0,4,0"/>

                        </HorizontalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>
</ContentPage>