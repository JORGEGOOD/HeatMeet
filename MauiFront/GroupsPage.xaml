<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:scheduler="clr-namespace:Syncfusion.Maui.Scheduler;assembly=Syncfusion.Maui.Scheduler"
             x:Class="MauiFront.GroupsPage"
             Title="Grupos"
             BackgroundColor="#F5EDE3">

    <Grid>
        <ScrollView ZIndex="1">
            <VerticalStackLayout Spacing="0">

                <!--Boton Calendario de volver al mes-->
                <Button Text="← Volver al Mes"
                        Clicked="VolverAlMes_Clicked"
                        BackgroundColor="#0A2A43"
                        TextColor="White"
                        CornerRadius="10"
                        HeightRequest="40"
                        HorizontalOptions="Start"
                        Margin="20,15,0,0"
                        FontSize="12">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button" 
                                     Binding="{Binding Source={x:Reference SchedulerControl}, Path=View}" 
                                     Value="Month">
                            <Setter Property="IsVisible" Value="False" />
                        </DataTrigger>
                    </Button.Triggers>
                </Button>

                <!--Calendario-->
                <Frame HeightRequest="500" 
                       Margin="15,15,15,5"
                       BackgroundColor="White"
                       CornerRadius="20"
                       BorderColor="Transparent"
                       HasShadow="True"
                       Padding="0">

                    <scheduler:SfScheduler x:Name="SchedulerControl"
                                           View="Month"
                                           Tapped="OnSchedulerTapped"
                                           AppointmentsSource="{Binding EventosAgendados}">
                    </scheduler:SfScheduler>
                </Frame>

                <!-- Toggle Modo disponibilidad -->
                <HorizontalStackLayout HorizontalOptions="Center" Margin="0,10" Spacing="10">
                    <Label Text="Modo Disponibilidad" VerticalOptions="Center" FontAttributes="Bold" TextColor="#0A2A43"/>
                    <Switch x:Name="DisponibilidadSwitch" 
                    OnColor="#FF6A00" 
                    ThumbColor="#0A2A43"
                    IsToggled="{Binding IsVotandoDisponibilidad}"/>
                </HorizontalStackLayout>

                <!--
                < Boton "Selecciona tus dias libres" 
                <Button x:Name="StatusBtn"
                    Text="Selecciona tus días libres"
                    IsVisible="{Binding Source={x:Reference DisponibilidadSwitch}, Path=IsToggled}"
                    BackgroundColor="#FF6A00"
                    TextColor="White"
                    CornerRadius="20"
                    HeightRequest="30"
                    FontSize="10"
                    Margin="50,0,50,15"
                    InputTransparent="True"
                />   
                -->


                <!-- Mis Grupos -->
                <Label Text="Mis Grupos" 
                       FontSize="22" 
                       FontAttributes="Bold" 
                       TextColor="#0A2A43" 
                       Margin="20,10,0,0"/>

                <CollectionView x:Name="GroupsCollection"
                                Margin="15,0,15,100" 
                                SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame Margin="0,10"
                                   Padding="15"
                                   CornerRadius="18"
                                   BackgroundColor="White"
                                   BorderColor="#0A2A43"
                                   HasShadow="True">
                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnGroupTapped" />
                                </Frame.GestureRecognizers>
                                <HorizontalStackLayout Spacing="15">
                                    <Image Source="{Binding DisplayImage}"
                                           HeightRequest="60"
                                           WidthRequest="60"
                                           Aspect="AspectFill">
                                        <Image.Clip>
                                            <RoundRectangleGeometry CornerRadius="12" Rect="0,0,60,60"/>
                                        </Image.Clip>
                                    </Image>
                                    <Label Text="{Binding Name}"
                                           VerticalOptions="Center"
                                           FontSize="18"
                                           FontAttributes="Bold"
                                           TextColor="#072033"/>
                                </HorizontalStackLayout>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </ScrollView>

        <BoxView x:Name="Overlay"
                 BackgroundColor="#80000000"
                 IsVisible="False"
                 Opacity="0"
                 ZIndex="10">
            <BoxView.GestureRecognizers>
                <TapGestureRecognizer Tapped="ToggleFabMenu"/>
            </BoxView.GestureRecognizers>
        </BoxView>

        <HorizontalStackLayout x:Name="CrearLayout" Opacity="0" Scale="0.8" IsVisible="False" Spacing="10" HorizontalOptions="End" VerticalOptions="End" Margin="25,0,25,110" ZIndex="20">
            <Frame BackgroundColor="White" Padding="10" CornerRadius="12" HasShadow="True">
                <Label Text="Crear grupo" TextColor="Black"/>
            </Frame>
            <Button BackgroundColor="#0A2A43" HeightRequest="55" WidthRequest="55" CornerRadius="28" Text="+" TextColor="White" Clicked="CreateNewGroup"/>
        </HorizontalStackLayout>

        <HorizontalStackLayout x:Name="UnirseLayout" Opacity="0" Scale="0.8" IsVisible="False" Spacing="10" HorizontalOptions="End" VerticalOptions="End" Margin="25,0,25,180" ZIndex="20">
            <Frame BackgroundColor="White" Padding="10" CornerRadius="12" HasShadow="True">
                <Label Text="Unirse a grupo" TextColor="Black"/>
            </Frame>
            <Button BackgroundColor="#0A2A43" HeightRequest="55" WidthRequest="55" CornerRadius="28" Text="⇄" TextColor="White" Clicked="IrUnirseGrupo"/>
        </HorizontalStackLayout>

        <Button x:Name="FabButton" Text="+" ZIndex="30" FontSize="32" TextColor="White" HeightRequest="65" WidthRequest="65" CornerRadius="33" HorizontalOptions="End" VerticalOptions="End" Margin="25" Clicked="ToggleFabMenu">
            <Button.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#FF6A00" Offset="0.0"/>
                    <GradientStop Color="#E63900" Offset="1.0"/>
                </LinearGradientBrush>
            </Button.Background>
            <Button.Shadow>
                <Shadow Brush="#30000000" Offset="0,4" Radius="14"/>
            </Button.Shadow>
        </Button>

    </Grid>
</ContentPage>