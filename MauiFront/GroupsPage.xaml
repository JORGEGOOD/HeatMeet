<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiFront.GroupsPage"
             Title="Grupos"
             BackgroundColor="#F5EDE3">

    <Grid>

        <!-- LISTA DE GRUPOS -->
        <CollectionView x:Name="GroupsCollection"
                        Margin="15"
                        ZIndex="1">

            <CollectionView.ItemTemplate>
                <DataTemplate>

                    <Frame Margin="0,10"
                           Padding="15"
                           CornerRadius="18"
                           BackgroundColor="White"
                           BorderColor="#0A2A43"
                           HasShadow="True">

                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnGroupTapped" />
                        </Frame.GestureRecognizers>

                        <HorizontalStackLayout Spacing="15">

                            <Image Source="{Binding DisplayImage}"
                                   HeightRequest="60"
                                   WidthRequest="60"
                                   Aspect="AspectFill">
                                <Image.Clip>
                                    <RoundRectangleGeometry CornerRadius="12"
                                                            Rect="0,0,60,60"/>
                                </Image.Clip>
                            </Image>

                            <Label Text="{Binding Name}"
                                   VerticalOptions="Center"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="#072033"/>
                        </HorizontalStackLayout>

                    </Frame>

                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- OVERLAY OSCURO -->
        <BoxView x:Name="Overlay"
                 BackgroundColor="#80000000"
                 IsVisible="False"
                 Opacity="0"
                 ZIndex="10">
            <BoxView.GestureRecognizers>
                <TapGestureRecognizer Tapped="ToggleFabMenu"/>
            </BoxView.GestureRecognizers>
        </BoxView>

        <!-- OPCIÓN: CREAR GRUPO -->
        <HorizontalStackLayout x:Name="CrearLayout"
                               Opacity="0"
                               Scale="0.8"
                               IsVisible="False"
                               Spacing="10"
                               HorizontalOptions="End"
                               VerticalOptions="End"
                               Margin="25,0,25,110"
                               ZIndex="20">

            <Frame BackgroundColor="White"
                   Padding="10"
                   CornerRadius="12"
                   HasShadow="True">
                <Label Text="Crear grupo"
                       TextColor="Black"/>
            </Frame>

            <Button BackgroundColor="#0A2A43"
                    HeightRequest="55"
                    WidthRequest="55"
                    CornerRadius="28"
                    Text="+"
                    TextColor="White"
                    Clicked="CreateNewGroup"/>
        </HorizontalStackLayout>

        <!-- OPCIÓN: UNIRSE -->
        <HorizontalStackLayout x:Name="UnirseLayout"
                               Opacity="0"
                               Scale="0.8"
                               IsVisible="False"
                               Spacing="10"
                               HorizontalOptions="End"
                               VerticalOptions="End"
                               Margin="25,0,25,180"
                               ZIndex="20">

            <Frame BackgroundColor="White"
                   Padding="10"
                   CornerRadius="12"
                   HasShadow="True">
                <Label Text="Unirse a grupo"
                       TextColor="Black"/>
            </Frame>

            <Button BackgroundColor="#0A2A43"
                    HeightRequest="55"
                    WidthRequest="55"
                    CornerRadius="28"
                    Text="⇄"
                    TextColor="White"
                    Clicked="IrUnirseGrupo"/>
        </HorizontalStackLayout>

        <!-- BOTÓN PRINCIPAL -->
        <Button x:Name="FabButton"
                Text="+"
                ZIndex="30"
                FontSize="32"
                TextColor="White"
                HeightRequest="65"
                WidthRequest="65"
                CornerRadius="33"
                HorizontalOptions="End"
                VerticalOptions="End"
                Margin="25"
                Clicked="ToggleFabMenu">

            <Button.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#FF6A00" Offset="0.0"/>
                    <GradientStop Color="#E63900" Offset="1.0"/>
                </LinearGradientBrush>
            </Button.Background>

            <Button.Shadow>
                <Shadow Brush="#30000000" Offset="0,4" Radius="14"/>
            </Button.Shadow>

        </Button>

    </Grid>
</ContentPage>